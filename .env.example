# =================================================================
# LynxKit 环境变量样例
# 复制此文件为 .env 并填入真实值
# =================================================================

# 运行环境
NODE_ENV=development

# ---- 后端 API (apps/api) ----
API_PORT=4000
API_HOST=0.0.0.0

# 数据库 (PostgreSQL 16)
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://lynxkit:lynxkit_dev@localhost:5432/lynxkit?schema=public

# Redis (BullMQ 队列 + 缓存)
REDIS_URL=redis://:lynxkit_redis@localhost:6379/0

# 认证 (NextAuth.js v5 - JWT 跨端鉴权)
# 生成: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_random_32_byte_secret_replace_with_random
NEXTAUTH_URL=http://localhost:4000
JWT_SECRET=replace_with_random_32_byte_secret_replace_with_random
JWT_EXPIRES_IN=7d

# ---- Web 端 (apps/web) ----
WEB_PORT=3000
# Web 调用后端 API 的地址（浏览器访问）
NEXT_PUBLIC_API_URL=http://localhost:4000
# Web 调用 tRPC 的地址（服务端/客户端）
NEXT_PUBLIC_TRPC_URL=http://localhost:4000/trpc

# ---- KMS 加密 (SSH 凭证加密) ----
# 主密钥，必须为 32 字节 hex 字符串（64 字符）
# 生成: openssl rand -hex 32
KMS_MASTER_KEY=replace_with_random_32_byte_hex_replace_with_random_hex

# ---- AI Provider (Agent 编排引擎) ----
# 留空则使用 Mock 实现
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- 推送服务（移动端）----
# Firebase Cloud Messaging (Android + iOS)
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# ---- 部署相关 ----
# 平台默认部署根目录（用户服务器上）
LYNX_PROJECT_ROOT=/opt/lynx/projects
# 平台默认域名
LYNX_DEFAULT_DOMAIN=lynx.run
