# API 部署环境变量示例（复制为 .env 并填入真实值）
NODE_ENV=production
PORT=8788
DATABASE_URL=postgresql://lynxkit:<password>@127.0.0.1:5432/lynxkit
BETTER_AUTH_SECRET=<32+ chars random string>
BETTER_AUTH_URL=https://miaox.lynxdo.com
KMS_MASTER_KEY=<64 hex chars random string>
CORS_ORIGINS=https://miaox.lynxdo.com,https://miao.lynxdo.com,http://localhost:3000,http://localhost:5173,capacitor://localhost,http://localhost

# Sentry 错误监控（注册 https://sentry.io 获取 DSN，留空则不上报）
SENTRY_DSN=

# Redis（BullMQ 队列 + 缓存层；未配置时 API 同步降级，缓存层降级为无缓存）
REDIS_URL=

# Prometheus 监控（迭代 14E 新增）
# 默认启用；/metrics 端点需通过防火墙或 Nginx 限制仅内网访问
PROMETHEUS_ENABLED=true
