# API 部署环境变量示例（复制为 .env 并填入真实值）
NODE_ENV=production
PORT=8788
DATABASE_URL=postgresql://lynxkit:<password>@127.0.0.1:5432/lynxkit
BETTER_AUTH_SECRET=<32+ chars random string>
BETTER_AUTH_URL=https://miaox.lynxdo.com
KMS_MASTER_KEY=<64 hex chars random string>
CORS_ORIGINS=https://miaox.lynxdo.com,http://localhost:3000,http://localhost:5173,capacitor://localhost,http://localhost

# Sentry 错误监控（注册 https://sentry.io 获取 DSN，留空则不上报）
SENTRY_DSN=

# Redis（可选，用于 BullMQ 队列；未配置时 API 同步降级）
REDIS_URL=
