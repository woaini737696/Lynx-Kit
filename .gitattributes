# 强制 LF 换行符，避免 Windows 下 CRLF 问题
* text=auto eol=lf

# Windows 批处理保持 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.dll binary
*.exe binary
*.so binary
*.dylib binary
*.dylib binary

# Flutter / Dart
*.dart text eol=lf
*.yaml text eol=lf
*.lock text eol=lf
