{
  "name": "@lynxkit/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LynxKit 后端 API 服务（Hono + Better Auth + Drizzle ORM）",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "worker": "tsx watch src/queues/build-worker.ts",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^0.0.1",
    "@hono/node-server": "^2.0.6",
    "@hono/swagger-ui": "^0.4.0",
    "@hono/zod-validator": "^0.4.1",
    "@lynxkit/db": "workspace:*",
    "@lynxkit/shared": "workspace:*",
    "@neondatabase/serverless": "^0.9.0",
    "@sentry/node": "^8.30.0",
    "@upstash/ratelimit": "^2.0.1",
    "@upstash/redis": "^1.34.0",
    "ai": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.0.0",
    "bullmq": "^5.13.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "hono-openapi": "^0.3.0",
    "ioredis": "^5.4.0",
    "jose": "^5.9.0",
    "nanoid": "^5.0.7",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "postgres": "^3.4.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.24.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
