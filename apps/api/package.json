{
  "name": "@lynxkit/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LynxKit 后端 API 服务（Fastify + tRPC + Prisma）",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.0",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@lynxkit/shared": "workspace:*",
    "@prisma/client": "^5.22.0",
    "@trpc/next": "^11.0.0-rc.660",
    "@trpc/openapi": "^0.7.1",
    "@trpc/server": "^11.0.0-rc.660",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "next-auth": "^5.0.0-beta.25",
    "node-ssh": "^13.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.14.0",
    "prisma": "^5.22.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.0"
  }
}
