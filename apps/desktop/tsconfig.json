{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "noEmit": true,
    "incremental": true,
    "moduleResolution": "Bundler",
    "types": ["vite/client"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "electron/**/*.ts",
    "electron-vite.config.ts"
  ],
  "exclude": ["node_modules", "dist", "out", ".turbo"]
}
