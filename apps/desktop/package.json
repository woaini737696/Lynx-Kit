{
  "name": "@lynxkit/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LynxKit 桌面端 - Electron 30 + Vite 5 + React 19 + React Router 7 + shadcn/ui，复用 @lynxkit/ui-web 组件库",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --publish never",
    "build:renderer": "electron-vite build",
    "build:electron": "electron-vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist dist-electron .turbo out",
    "dist": "electron-builder --publish never"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@lynxkit/api-client": "workspace:*",
    "@lynxkit/shared": "workspace:*",
    "@lynxkit/store": "workspace:*",
    "@lynxkit/ui-web": "workspace:*",
    "@tanstack/react-query": "^5.59.16",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.439.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.0.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.14",
    "web-vitals": "^5.3.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@lynxkit/config": "workspace:*",
    "@types/node": "^22.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.47",
    "rimraf": "^5.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-tsconfig-paths": "^5.0.0",
    "wait-on": "^8.0.1"
  }
}
