{
  "id": "event-manage",
  "name": "活动管理",
  "description": "活动报名、会议签到、课程管理、聚会组织",
  "architecture": "event",
  "version": "1.0.0",
  "features": [
    "活动详情页 + 报名表单",
    "名额限制（先到先得 / 审核制）",
    "报名确认邮件",
    "二维码签到（生成 + 扫描）",
    "报名名单导出（Excel）",
    "重复报名检测",
    "PWA 离线签到"
  ],
  "screenshots": [
    "home.png",
    "event.png",
    "signup.png",
    "checkin.png"
  ],
  "questions": [
    {
      "id": "eventName",
      "question": "活动名称？",
      "type": "text",
      "required": true,
      "placeholder": "LynxCon 2026"
    },
    {
      "id": "organizer",
      "question": "主办方名称？",
      "type": "text",
      "required": true,
      "placeholder": "LynxKit 社区"
    },
    {
      "id": "description",
      "question": "活动简介",
      "type": "textarea",
      "required": false,
      "placeholder": "一场关于独立产品构建的聚会..."
    },
    {
      "id": "primaryColor",
      "question": "主色调偏好？",
      "type": "color-select",
      "required": true,
      "default": "#8B5CF6",
      "options": [
        { "label": "紫色", "value": "#8B5CF6" },
        { "label": "暖橙", "value": "#FF6B35" },
        { "label": "深蓝", "value": "#1e40af" },
        { "label": "墨绿", "value": "#065f46" },
        { "label": "黑白", "value": "#111827" }
      ]
    },
    {
      "id": "registrationType",
      "question": "报名方式？",
      "type": "select",
      "required": true,
      "default": "先到先得",
      "options": [
        "先到先得",
        "审核制",
        "邀请码"
      ]
    },
    {
      "id": "maxAttendees",
      "question": "报名人数上限？",
      "type": "number",
      "required": false,
      "placeholder": "100",
      "default": 100
    },
    {
      "id": "checkinEnabled",
      "question": "是否启用现场二维码签到？",
      "type": "select",
      "required": true,
      "default": "启用",
      "options": [
        "启用",
        "禁用"
      ]
    },
    {
      "id": "contactPhone",
      "question": "联系电话",
      "type": "text",
      "required": false,
      "placeholder": "13800138000"
    },
    {
      "id": "contactEmail",
      "question": "联系邮箱",
      "type": "text",
      "required": true,
      "placeholder": "events@example.com"
    }
  ],
  "configMapping": {
    "eventName": "config.eventName",
    "organizer": "config.organizer",
    "description": "config.description",
    "primaryColor": "config.theme.primaryColor",
    "registrationType": "config.registration.type",
    "maxAttendees": "config.registration.maxAttendees",
    "checkinEnabled": "config.checkin.enabled",
    "contactPhone": "config.contact.phone",
    "contactEmail": "config.contact.email"
  }
}
