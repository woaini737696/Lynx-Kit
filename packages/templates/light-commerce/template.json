{
  "id": "light-commerce",
  "name": "电商交易",
  "description": "手作商城、知识付费、会员订阅、虚拟商品",
  "architecture": "commerce",
  "version": "1.0.0",
  "features": [
    "首页商品橱窗",
    "商品详情 + SKU 选择",
    "购物车 + 结算",
    "Stripe 在线支付",
    "订单管理后台",
    "运费规则（可选）"
  ],
  "screenshots": [
    "home.png",
    "product.png",
    "cart.png",
    "admin.png"
  ],
  "questions": [
    {
      "id": "shopName",
      "question": "店铺名称？",
      "type": "text",
      "required": true,
      "placeholder": "Lynx 手作铺"
    },
    {
      "id": "description",
      "question": "店铺简介（用于首页与 SEO）",
      "type": "textarea",
      "required": false,
      "placeholder": "亲手制作的手工艺品与设计..."
    },
    {
      "id": "primaryColor",
      "question": "主色调偏好？",
      "type": "color-select",
      "required": true,
      "default": "#EF4444",
      "options": [
        { "label": "暖橙", "value": "#FF6B35" },
        { "label": "深蓝", "value": "#1e40af" },
        { "label": "墨绿", "value": "#065f46" },
        { "label": "玫红", "value": "#be185d" },
        { "label": "黑白", "value": "#111827" }
      ]
    },
    {
      "id": "paymentMethod",
      "question": "支付方式？",
      "type": "select",
      "required": true,
      "default": "Stripe",
      "options": [
        "Stripe",
        "支付宝",
        "微信支付",
        "PayPal"
      ]
    },
    {
      "id": "currency",
      "question": "结算币种？",
      "type": "select",
      "required": true,
      "default": "CNY",
      "options": [
        { "label": "人民币 CNY", "value": "CNY" },
        { "label": "美元 USD", "value": "USD" },
        { "label": "欧元 EUR", "value": "EUR" },
        { "label": "日元 JPY", "value": "JPY" }
      ]
    },
    {
      "id": "shippingEnabled",
      "question": "是否启用物流发货？",
      "type": "select",
      "required": true,
      "default": "启用",
      "options": [
        "启用",
        "禁用（仅虚拟商品）"
      ]
    },
    {
      "id": "categories",
      "question": "商品分类（每行一项）",
      "type": "textarea",
      "required": false,
      "placeholder": "手作\n印刷品\n数字模板"
    },
    {
      "id": "productDisplay",
      "question": "商品列表展示样式？",
      "type": "select",
      "required": true,
      "default": "网格",
      "options": [
        "网格",
        "列表",
        "瀑布流"
      ]
    },
    {
      "id": "contactPhone",
      "question": "客服电话",
      "type": "text",
      "required": false,
      "placeholder": "13800138000"
    },
    {
      "id": "contactEmail",
      "question": "客服邮箱",
      "type": "text",
      "required": true,
      "placeholder": "support@example.com"
    },
    {
      "id": "logo",
      "question": "上传店铺 Logo",
      "type": "image",
      "required": false
    }
  ],
  "configMapping": {
    "shopName": "config.shopName",
    "description": "config.description",
    "primaryColor": "config.theme.primaryColor",
    "paymentMethod": "config.payment.method",
    "currency": "config.payment.currency",
    "shippingEnabled": "config.shipping.enabled",
    "categories": "config.categories",
    "productDisplay": "config.product.display",
    "contactPhone": "config.contact.phone",
    "contactEmail": "config.contact.email",
    "logo": "config.brand.logo"
  }
}
