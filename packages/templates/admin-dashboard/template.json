{
  "id": "admin-dashboard",
  "name": "管理后台",
  "description": "内部工具、客户管理、数据看板、CRM 轻量版",
  "architecture": "admin",
  "version": "1.0.0",
  "features": [
    "登录页",
    "仪表盘（数据卡片 + 简单图表）",
    "数据表格（CRUD + 筛选 + 排序 + 分页）",
    "表单页（创建 / 编辑）",
    "详情页",
    "设置页",
    "用户 / 角色 / 权限管理（RBAC）",
    "操作日志",
    "数据导入 / 导出（CSV / Excel）",
    "通知中心",
    "主题切换（浅色 / 深色）"
  ],
  "screenshots": [
    "dashboard.png",
    "table.png",
    "form.png",
    "settings.png"
  ],
  "questions": [
    {
      "id": "appName",
      "question": "应用名称？",
      "type": "text",
      "required": true,
      "placeholder": "Lynx CRM"
    },
    {
      "id": "description",
      "question": "应用简介（用于登录页说明）",
      "type": "textarea",
      "required": false,
      "placeholder": "内部客户管理系统..."
    },
    {
      "id": "primaryColor",
      "question": "主题色？",
      "type": "color-select",
      "required": true,
      "default": "#06B6D4",
      "options": [
        { "label": "青蓝", "value": "#06B6D4" },
        { "label": "暖橙", "value": "#FF6B35" },
        { "label": "深蓝", "value": "#1e40af" },
        { "label": "墨绿", "value": "#065f46" },
        { "label": "黑白", "value": "#111827" }
      ]
    },
    {
      "id": "authEnabled",
      "question": "是否启用登录认证？",
      "type": "select",
      "required": true,
      "default": "启用",
      "options": [
        "启用",
        "禁用"
      ]
    },
    {
      "id": "rbacEnabled",
      "question": "是否启用 RBAC 角色权限？",
      "type": "select",
      "required": true,
      "default": "启用",
      "options": [
        "启用",
        "禁用"
      ]
    },
    {
      "id": "dataExportEnabled",
      "question": "是否启用数据导入 / 导出？",
      "type": "select",
      "required": true,
      "default": "启用",
      "options": [
        "启用",
        "禁用"
      ]
    },
    {
      "id": "logRetentionDays",
      "question": "操作日志保留天数？",
      "type": "number",
      "required": false,
      "default": 30,
      "placeholder": "30"
    }
  ],
  "configMapping": {
    "appName": "config.appName",
    "description": "config.description",
    "primaryColor": "config.theme.primaryColor",
    "authEnabled": "config.features.auth",
    "rbacEnabled": "config.features.rbac",
    "dataExportEnabled": "config.features.dataExport",
    "logRetentionDays": "config.log.retentionDays"
  }
}
