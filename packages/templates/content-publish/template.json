{
  "id": "content-publish",
  "name": "内容发布",
  "description": "个人博客、知识库、newsletter、文档站",
  "architecture": "content",
  "version": "1.0.0",
  "features": [
    "首页文章列表 + 分页",
    "MDX 文章渲染",
    "标签 / 分类筛选",
    "作者介绍页",
    "RSS 订阅",
    "评论（可选）"
  ],
  "screenshots": [
    "home.png",
    "post.png",
    "author.png"
  ],
  "questions": [
    {
      "id": "siteName",
      "question": "站点名称？",
      "type": "text",
      "required": true,
      "placeholder": "Lynx Blog"
    },
    {
      "id": "description",
      "question": "站点描述（用于 SEO 与首页副标题）",
      "type": "textarea",
      "required": false,
      "placeholder": "记录技术与生活..."
    },
    {
      "id": "primaryColor",
      "question": "主色调偏好？",
      "type": "color-select",
      "required": true,
      "default": "#F59E0B",
      "options": [
        { "label": "暖橙", "value": "#FF6B35" },
        { "label": "深蓝", "value": "#1e40af" },
        { "label": "墨绿", "value": "#065f46" },
        { "label": "玫红", "value": "#be185d" },
        { "label": "黑白", "value": "#111827" }
      ]
    },
    {
      "id": "authorName",
      "question": "作者姓名？",
      "type": "text",
      "required": true,
      "placeholder": "张三"
    },
    {
      "id": "authorBio",
      "question": "作者简介",
      "type": "textarea",
      "required": false,
      "placeholder": "工程师 / 写作者 / 数字游民"
    },
    {
      "id": "socialLinks",
      "question": "社交链接（每行一项：平台 - 链接）",
      "type": "textarea",
      "required": false,
      "placeholder": "GitHub - https://github.com/yourname\nTwitter - https://twitter.com/yourname"
    },
    {
      "id": "rssEnabled",
      "question": "是否启用 RSS 订阅？",
      "type": "select",
      "required": true,
      "default": "启用",
      "options": [
        "启用",
        "禁用"
      ]
    },
    {
      "id": "commentEnabled",
      "question": "是否启用文章评论？",
      "type": "select",
      "required": true,
      "default": "启用",
      "options": [
        "启用",
        "禁用"
      ]
    }
  ],
  "configMapping": {
    "siteName": "config.siteName",
    "description": "config.description",
    "primaryColor": "config.theme.primaryColor",
    "authorName": "config.author.name",
    "authorBio": "config.author.bio",
    "socialLinks": "config.socialLinks",
    "rssEnabled": "config.features.rss",
    "commentEnabled": "config.features.comment"
  }
}
