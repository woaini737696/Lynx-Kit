{
  "name": "@lynxkit/shared",
  "version": "0.1.0",
  "private": true,
  "description": "LynxKit 跨端共享类型、常量、工具函数",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./src/types/index.ts"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "default": "./src/constants/index.ts"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "default": "./src/utils/index.ts"
    },
    "./crypto": {
      "types": "./src/crypto/index.ts",
      "default": "./src/crypto/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.5.0"
  }
}
